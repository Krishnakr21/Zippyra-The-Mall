# Auth Service Environment Variables Example
# Copy this file to .env and fill in the actual values

# 1. General Config
PORT=8080
APP_ENV=local
VERSION=1.0.0
LOG_LEVEL=debug

# 2. Database (PostgreSQL)
# Format: postgres://user:pass@host:port/dbname
DATABASE_URL=postgres://postgres:postgres@localhost:5432/zippya_auth?sslmode=disable

# 3. Cache (Redis)
# Format: redis://host:port/db_number
REDIS_URL=redis://localhost:6379/0

# 4. Message Bus (Kafka)
# Comma-separated list of brokers
KAFKA_BROKERS=localhost:9092

# 5. Security (Ed25519 JWT Keys)
# These MUST be base64-encoded strings of your PEM keys.
# Run: cat private.pem | base64
JWT_PRIVATE_KEY=
# Run: cat public.pem | base64
JWT_PUBLIC_KEY=

# 6. OTP & Communications
# Minimum 32 characters
OTP_SALT=your-long-secure-salt-at-least-32-chars-long
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SERVICE_SID=

# 7. Observability
ALLOWED_ORIGINS=*
JAEGER_ENDPOINT=localhost:4317
SENTRY_DSN=
