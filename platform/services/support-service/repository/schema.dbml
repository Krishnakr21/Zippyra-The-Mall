// =============================================================================
// GROUP 12 — SUPPORT SERVICE
// Tables: tickets, ticket_messages
// =============================================================================

Table tickets {
  id              uuid          [pk, default: `gen_random_uuid()`]
  user_id         uuid          [not null, ref: > users.id]
  order_id        uuid          [null, ref: > orders.id, note: 'Set when ticket is raised from exit.denied or refund.requested event; null for general support']
  subject         varchar(500)  [not null]
  status          varchar(30)   [not null, default: 'OPEN', note: 'OPEN | IN_PROGRESS | ESCALATED | RESOLVED | CLOSED']
  assigned_to     uuid          [null, ref: > users.id, note: 'Support agent assigned to this ticket; null when unassigned (OPEN state)']
  created_at      timestamptz   [not null, default: `now()`]
  updated_at      timestamptz   [not null, default: `now()`, note: 'Updated on every status transition and reassignment. Powers recently-updated sort and stale-ticket detection.']
  resolved_at     timestamptz   [null]
  sla_target      timestamptz   [not null, note: 'SLA deadline = created_at + 2hr; escalation triggered if unresolved by this time']

  indexes {
    user_id        [name: 'idx_tickets_user_id']
    order_id       [name: 'idx_tickets_order_id']
    status         [name: 'idx_tickets_status']
    assigned_to    [name: 'idx_tickets_assigned_to', note: 'Agent workload view: all open tickets assigned to me']
    sla_target     [name: 'idx_tickets_sla_target', note: 'Escalation job scans for tickets where now() > sla_target']
    created_at     [name: 'idx_tickets_created_at']
    updated_at     [name: 'idx_tickets_updated_at']
  }

  Note: 'Support Service owner. assigned_to links to the agent handling the ticket (null = unassigned). SLA escalation after 2hr unresolved. Consumed from exit.denied and refund.requested Kafka events.'
}


// [GAP-B] ticket_messages — Referenced in Flow B-6
// "PostgreSQL --- tickets, ticket_messages" — tickets table existed but ticket_messages was not defined
Table ticket_messages {
  id              uuid          [pk, default: `gen_random_uuid()`]
  ticket_id       uuid          [not null, ref: > tickets.id]
  sender_id       uuid          [null, ref: > users.id, note: 'Null for SYSTEM/BOT messages. For CUSTOMER = tickets.user_id. For AGENT = the staff member. Required for agent response-time metrics.']
  sender_role     varchar(20)   [not null, note: 'CUSTOMER | AGENT | SYSTEM | BOT']
  message         text          [not null]
  sent_at         timestamptz   [not null, default: `now()`]

  indexes {
    ticket_id      [name: 'idx_ticket_messages_ticket_id']
    sender_id      [name: 'idx_ticket_messages_sender_id']
    sent_at        [name: 'idx_ticket_messages_sent_at']
    (ticket_id, sent_at) [name: 'idx_ticket_messages_ticket_sent', note: 'Powers threaded conversation view ordered by time']
  }

  Note: '[GAP-B FIX] Required for Flow B-6 Support Tickets. sender_id identifies which agent replied — required for agent performance and SLA measurement.'
}


// =============================================================================
// TABLE GROUPS — organise by service in dbdiagram.io
// =============================================================================

TableGroup auth_service {
  users
  auth_events
  admin_actions
  login_attempts
  email_verifications
  app_versions
}

TableGroup store_service {
  stores
  store_hours
  store_qr_tokens
  beacon_verifications
  aisle_layout
  shelf_positions
}

TableGroup catalog_service {
  categories
  products
  pricing_rules
  offers
  offer_rules
  combo_rules
  combo_items
  recipes
  recipe_ingredients
}

TableGroup cart_service {
  coupons
  coupon_usage
  hsn_gst_rates
}

TableGroup inventory_service {
  stock
}

TableGroup order_service {
  orders
  order_items
  refunds
  refund_requests
  approval_workflow
}

TableGroup payment_service {
  payments
  tokenized_cards
  reconciliation_log
  payment_audit_log
}

TableGroup loyalty_service {
  loyalty_ledger
  loyalty_tiers
  loyalty_cards
  loyalty_tier_history
}

TableGroup exit_validation_service {
  exit_tokens
  override_log
}

TableGroup warehouse_service {
  warehouse_stock
  transfers
}

TableGroup notification_service {
  user_notification_prefs
  notification_delivery_log
}

TableGroup support_service {
  tickets
  ticket_messages
}


// =============================================================================
// END OF SCHEMA — PASS 9 — TRULY FINAL (EXHAUSTIVE TABLE-BY-TABLE AUDIT)
// 46 tables | 12 service groups | 74 FK refs
// All 33 document gaps resolved. All passes verified.
//
// PASS 9 FIXES (exhaustive table-by-table read — every table as if building from scratch):
//   1.  stores.address + city + state — store listing UI and support context needs readable location
//   2.  products.weight_unit — sold_by_weight=true needs unit label (kg/g/100g) for price display
//   3.  combo_rules.discount_type — PERCENT|FLAT|FREE_ITEM; discount_value alone is ambiguous
//   4.  orders.loyalty_points_redeemed — split coupon vs loyalty in reconciliation; snapshot not derived
//   5.  tokenized_cards.is_active + index — UX needs soft remove; hard delete breaks audit trail
//   6.  tickets.updated_at + index — status transitions need updated_at for recently-updated sort
//
// PASS 8 FIXES (service build simulation — 7 real gaps found):
//   1.  products.is_active — soft delist flag (FK on order_items prevents hard delete)
//   2.  products.is_active index — added
//   3.  transfers.received_at — RECEIVED status had no timestamp (dispatched_at existed)
//   4.  transfers.received_at index — added
//   5.  ticket_messages.sender_id — FK to users.id (AGENT role needs identity for metrics)
//   6.  ticket_messages.sender_id index — added
//   7.  loyalty_ledger.notes — ADJUSTMENT type needs human-readable reason for user statement
//   8.  notification_delivery_log.provider_message_id — webhook delivery confirmation lookup
//   9.  notification_delivery_log.error_details — FAILED/BOUNCED needs error for retry logic
//   10. notification_delivery_log.provider_message_id index — added
//   11. offers.starts_at — flash sales need window start; active flag alone insufficient
//   12. offers.starts_at index — added
//   13. admin_actions.target_type — bare target_id uuid is unjoiable without entity type
//   14. admin_actions.target_type index — added
//   15. admin_actions.(target_type, target_id) composite index — added
//   Note: pricing_rules composite index (product_id, store_id, effective_from) was
//         already present — confirmed not missing.
//
// PASS 7 FIXES: users.updated_at, combo_items UNIQUE(combo_id,sku_id),
//   recipe_ingredients UNIQUE(recipe_id,sku_id), orders.coupon_code+index,
//   exit_tokens.created_at, tickets.assigned_to+index, pricing_rules.created_at
// PASS 6 FIX: refund_requests.updated_at
// PASS 5 FIX: loyalty_tiers.updated_at
// PASS 4 FIXES: products.image_url+created_at+index, timestamps on coupons/combo_rules/
//   recipes/offer_rules/combo_items/recipe_ingredients/categories/stores/store_hours/
//   shelf_positions, tickets.order_id+index
// PASS 3 FIXES: shelf_positions.store_id+FK, offers.name+timestamps, stock timestamps,
//   refunds.payment_id, warehouse_stock.updated_at, transfers.created_at,
//   notification_delivery_log reference_id+type
// PASS 2 FIXES: shelf_positions.sku_id FK, products.category_id FK, coupon_usage.order_id
//   FK, order_items.created_at, loyalty_tier_history FKs, payment_audit_log (full table)
//
// INTENTIONAL DESIGN (not missing):
//   store_hours: updated_at only (config table, insert date irrelevant)
//   stock: no low_stock_threshold (app-level config, not per-row)
//   payments: no currency (India-only MVP, INR implicit)
//   payments: no user_id (always reachable via order_id → orders.user_id)
//   override_log: no order_id (reachable via exit_token_id → exit_tokens.order_id)
//   warehouse_stock: no UNIQUE on (sku_id,warehouse_id) — batch_no nullable, multi-GRN valid
//   aisle_layout: no version (updated_at signals app to refetch)
//   coupon_usage: no DB unique constraint (per_user_limit enforced at app layer)
//   loyalty_ledger: no offer_id (context flows via order_id + type enum)
//   order_items: no offer_id (per-item offer attribution is ClickHouse analytics concern)
//   store_qr_tokens: no user_id (token is store-issued; user identity via beacon_verifications)
//   auth_events: no session_id (application-layer concern; device_id+timestamp sufficient)
//   email_verifications: no created_at (expires_at = created_at + 24h; back-calculable)
//   stores: address nullable (lat/lng always present; address is display enrichment)
//
// ALL 33 DOCUMENT GAPS RESOLVED:
// [GAP-A] stock, store_qr_tokens, app_versions, email_verifications,
//   login_attempts, coupon_usage, categories, recipes, recipe_ingredients,
//   combo_rules, combo_items, refund_requests, products.sold_by_weight,
//   payments.retry_count, offer_rules (separate from offers)
// [GAP-B] warehouse_stock, transfers, admin_actions, tokenized_cards,
//   reconciliation_log, aisle_layout, shelf_positions, loyalty_tiers,
//   loyalty_cards, loyalty_tier_history, user_notification_prefs,
//   notification_delivery_log, ticket_messages, approval_workflow
// [GAP-C] aisle_layout name conflict, shelf_positions name conflict,
//   payment_events dual-role (payment_audit_log here + payment_analytics_events
//   in TimescaleDB diagram), offer_rules as separate table from offers
// =============================================================================
