// =============================================================================
// ZIPPYRA RETAIL INFRASTRUCTURE PLATFORM
// PostgreSQL Schema — DBML for dbdiagram.io
// Version: 4.0 Final | March 2026
// Covers: All 46 documented tables + 33 Gap fixes from Section 10
// Gap fixes are marked with: // [GAP-A], [GAP-B], [GAP-C]
// =============================================================================


// =============================================================================
// GROUP 6 — ORDER SERVICE
// Tables: orders, order_items, refunds, refund_requests, approval_workflow
// =============================================================================

Table orders {
  id                uuid          [pk, default: `gen_random_uuid()`]
  user_id           uuid          [not null, ref: > users.id]
  store_id          uuid          [not null, ref: > stores.id]
  status            varchar(30)   [not null, note: 'PENDING | PAYMENT_PROCESSING | CONFIRMED | EXIT_VALIDATED | COMPLETED | CANCELLED | REFUNDED']
  subtotal          decimal(12,2) [not null]
  gst               decimal(12,2) [not null]
  discount          decimal(12,2) [not null, default: 0]
  total             decimal(12,2) [not null]
  coupon_code              varchar(50)   [null, ref: > coupons.code, note: 'Applied coupon if any; null if no coupon used. Denormalised for support/audit visibility without joining coupon_usage.']
  loyalty_points_redeemed  integer       [not null, default: 0, note: 'Points burned in this order. 0 = no loyalty redemption. Snapshot — not derived from loyalty_ledger at query time. Required for reconciliation to split coupon vs loyalty discount.']
  exit_validated_at        timestamptz   [null, note: 'Set when exit_tokens.status transitions to USED']
  created_at        timestamptz   [not null, default: `now()`]
  updated_at        timestamptz   [not null, default: `now()`]

  indexes {
    user_id          [name: 'idx_orders_user_id']
    store_id         [name: 'idx_orders_store_id']
    status           [name: 'idx_orders_status']
    created_at       [name: 'idx_orders_created_at']
    (user_id, created_at) [name: 'idx_orders_user_created']
    coupon_code      [name: 'idx_orders_coupon_code']
  }

  Note: 'Event-sourced; immutable after COMPLETED status. Order Service owner. coupon_code denormalised for direct support lookup. PARTITION BY RANGE(created_at) required before Phase 2 scale.'
}


Table order_items {
  id              uuid          [pk, default: `gen_random_uuid()`]
  order_id        uuid          [not null, ref: > orders.id]
  sku_id          uuid          [not null, ref: > products.id]
  qty             integer       [not null]
  unit_price      decimal(10,2) [not null, note: 'Price at time of purchase — snapshot, not live lookup']
  gst_amount      decimal(10,2) [not null]
  rfid_tag_id     varchar(100)  [null, note: 'RFID tag scanned at exit gate; null for non-RFID items']
  created_at      timestamptz   [not null, default: `now()`, note: 'Required for PARTITION BY RANGE(created_at) before Phase 2 — document explicitly calls this out']

  indexes {
    order_id       [name: 'idx_order_items_order_id']
    sku_id         [name: 'idx_order_items_sku_id']
    rfid_tag_id    [name: 'idx_order_items_rfid_tag_id']
    created_at     [name: 'idx_order_items_created_at']
  }

  Note: 'Order Service owner. created_at required for PARTITION BY RANGE(created_at) before Phase 2 scale. Prices are snapshot at time of purchase.'
}


Table refunds {
  id                  uuid          [pk, default: `gen_random_uuid()`]
  order_id            uuid          [not null, ref: > orders.id]
  payment_id          uuid          [not null, ref: > payments.id, note: 'The payment being reversed; required to initiate gateway refund call']
  sku_id              uuid          [null, ref: > products.id, note: 'Null for full-order refunds']
  amount              decimal(10,2) [not null]
  reason              text          [null]
  status              varchar(30)   [not null, note: 'PENDING → PROCESSING → CREDITED | FAILED']
  gateway_refund_id   varchar(255)  [null, note: 'Payment gateway refund reference ID; set once gateway confirms']
  created_at          timestamptz   [not null, default: `now()`]
  updated_at          timestamptz   [not null, default: `now()`]

  indexes {
    order_id           [name: 'idx_refunds_order_id']
    payment_id         [name: 'idx_refunds_payment_id']
    status             [name: 'idx_refunds_status']
    sku_id             [name: 'idx_refunds_sku_id']
  }

  Note: 'Order Service owner. payment_id required — gateway refund call needs original payment gateway_ref. Status machine: PENDING → PROCESSING → CREDITED | FAILED.'
}


// [GAP-A] refund_requests — Flow A-6 "PostgreSQL --- refund_requests; approval_workflow"
// DISTINCT from refunds table — this is the customer-facing submission
Table refund_requests {
  id              uuid          [pk, default: `gen_random_uuid()`]
  order_id        uuid          [not null, ref: > orders.id]
  user_id         uuid          [not null, ref: > users.id]
  sku_id          uuid          [null, ref: > products.id, note: 'Specific item; null for full order refund request']
  reason          text          [not null]
  image_url       varchar(500)  [null, note: 'S3 URL: refunds/{order_id}/{refund_id}/{filename}.jpg — for damaged item photo']
  status          varchar(30)   [not null, default: 'SUBMITTED', note: 'SUBMITTED | UNDER_REVIEW | APPROVED | REJECTED']
  created_at      timestamptz   [not null, default: `now()`]
  updated_at      timestamptz   [not null, default: `now()`, note: 'Updated on every status transition']

  indexes {
    order_id       [name: 'idx_refund_requests_order_id']
    user_id        [name: 'idx_refund_requests_user_id']
    status         [name: 'idx_refund_requests_status']
  }

  Note: '[GAP-A FIX] Customer-facing refund submission table. DISTINCT from refunds. Contains image_url for damaged items per Flow A-6. Feeds into approval_workflow state machine.'
}


// [GAP-A] + [GAP-C] approval_workflow — Flow A-6 "PostgreSQL --- refund_requests; approval_workflow"
// Two distinct tables separated by semicolon — internal state machine for staff review
Table approval_workflow {
  id                  uuid          [pk, default: `gen_random_uuid()`]
  refund_request_id   uuid          [not null, ref: > refund_requests.id]
  reviewer_id         uuid          [not null, ref: > users.id, note: 'Staff/admin user performing the review']
  status              varchar(30)   [not null, note: 'PENDING_REVIEW | APPROVED | REJECTED | ESCALATED']
  decision_note       text          [null, note: 'Reviewer notes explaining the decision']
  actioned_at         timestamptz   [null, note: 'Null until reviewer makes a decision']
  created_at          timestamptz   [not null, default: `now()`]

  indexes {
    refund_request_id  [name: 'idx_approval_workflow_request_id']
    reviewer_id        [name: 'idx_approval_workflow_reviewer_id']
    status             [name: 'idx_approval_workflow_status']
  }

  Note: '[GAP-A FIX] [GAP-C FIX] Internal staff refund review state machine. Separate from refund_requests (customer submission) and refunds (gateway execution). Three-table refund flow: refund_requests → approval_workflow → refunds.'
}


// =============================================================================
