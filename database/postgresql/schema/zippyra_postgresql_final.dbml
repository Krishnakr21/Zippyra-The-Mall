  warehouse_stock
  transfers
}

TableGroup notification_service {
  user_notification_prefs
  notification_delivery_log
}

TableGroup support_service {
  tickets
  ticket_messages
}


// =============================================================================
// END OF SCHEMA — VERSION 5.0 — CROSS-SYSTEM VALIDATED
// 51 tables (was 46) | 13 service groups | ~90 FK refs
// 5 new tables: chains, auth_sessions, geofence_polygons, feature_flags, vendors
// 23 column additions across existing tables
//
// V5 CHANGES SUMMARY:
// NEW TABLES (5):
//   chains              — multi-chain architecture; FK target for stores and categories
//   auth_sessions       — JWT refresh token server-side store (30-day sliding)
//   geofence_polygons   — ES geo_shape polygon source; per-store optional
//   feature_flags       — WatermelonDB + Redis feature_flags source of truth
//   vendors             — TimescaleDB supply_chain_events.vendor_id FK target
//
// COLUMN ADDITIONS (23 across 8 tables):
//   stores:             chain_id, store_type, gstin, max_capacity
//   categories:         chain_id (REPLACED store_id — chain-scoped not store-scoped)
//   products:           brand, weight_grams, unit_of_measure, pack_size, rfid_required, cold_storage_required, tags
//   orders:             payment_id
//   payment_audit_log:  store_id
//   tickets:            priority
//   exit_tokens:        expires_at note corrected 30min→10min
//
// FK FIX (1):
//   coupon_usage.coupon_code varchar FK → coupon_id uuid FK (non-PK FK is unsafe)
//
// INTENTIONAL DESIGN DECISIONS:
//   warehouse_stock.warehouse_id: kept as varchar(100) for human-readable IDs (WH-BLR-01)
//     TimescaleDB supply_chain_events corrected to TEXT to match
//   categories: store_id removed, chain_id added — 15M stores cannot each have separate category trees
//   exit_tokens.expires_at: 10 min (down from 30 min) — matches 100M scale QR security spec
// =============================================================================
