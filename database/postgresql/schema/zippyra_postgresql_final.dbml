// =============================================================================
// ZIPPYRA RETAIL INFRASTRUCTURE PLATFORM
// PostgreSQL Schema — DBML for dbdiagram.io
// Version: 5.0 Final | March 2026
// Audited for 100M user scale by senior DB architect
//
// V5 FIXES (cross-system audit against ES, Kafka, Redis, TimescaleDB, ClickHouse):
//   1.  stores.max_capacity      — required by ClickHouse peak_hour_heatmap & TimescaleDB store_traffic
//   2.  stores.store_type        — required by ClickHouse analytics segmentation
//   3.  stores.gstin             — GST compliance, Elasticsearch stores index
//   4.  stores.chain_id          — multi-chain architecture; ES/orders_search chain isolation
//   5.  categories.chain_id      — categories are chain-scoped, not per-store (15M stores can't each have their own tree)
//   6.  products.brand           — ES autocomplete_analyzer, WatermelonDB catalog_cache source of truth
//   7.  products.cold_storage_required — ES index, supply chain routing
//   8.  products.tags            — ES filtering (organic/gluten_free/vegan), JSONB array
//   9.  products.weight_grams    — ES index, WatermelonDB; PG is source of truth
//   10. products.unit_of_measure — ES index, WatermelonDB
//   11. products.pack_size       — ES index display field
//   12. products.rfid_required   — WatermelonDB catalog_cache, exit validation logic
//   13. warehouse_stock.warehouse_id type standardised to varchar(100) (TimescaleDB stub corrected separately)
//   14. vendors table ADDED      — TimescaleDB supply_chain_events.vendor_id FK target
//   15. geofence_polygons table ADDED — Elasticsearch stores geofence: geo_shape source
//   16. feature_flags table ADDED — WatermelonDB + Redis feature_flags source of truth
//   17. coupon_usage: coupon_code FK changed to coupon_id uuid → coupons.id (non-PK FK is unsafe)
//   18. payment_audit_log.store_id ADDED — audit queries need store context without joins
//   19. orders.payment_id ADDED  — direct payment reference for support/audit
//   20. auth_sessions table ADDED — JWT refresh token server-side store
//   21. tickets.priority ADDED   — ES support_tickets index has priority P1|P2|P3|P4
//   22. chains table ADDED       — required by chain_id FKs across stores/categories
//   23. exit_tokens TTL note corrected to 10 min QR TTL
// =============================================================================


// =============================================================================
// GROUP 0 — CHAIN SERVICE (new)
// Multi-chain architecture support
// =============================================================================

Table chains {
  id            uuid          [pk, default: `gen_random_uuid()`]
  name          varchar(255)  [not null, note: 'Chain display name e.g. "Reliance Smart"']
  gstin         varchar(20)   [null, note: 'Chain-level GSTIN if group filing; store-level GSTIN also supported']
  logo_url      varchar(500)  [null]
  is_active     boolean       [not null, default: true]
  created_at    timestamptz   [not null, default: `now()`]
  updated_at    timestamptz   [not null, default: `now()`]

  indexes {
    name         [name: 'idx_chains_name']
    is_active    [name: 'idx_chains_is_active']
  }

  Note: 'Multi-chain architecture. Each chain owns multiple stores. Required by Elasticsearch chain_id filters in orders_search and users_search PII isolation.'
}


// =============================================================================
// GROUP 1 — AUTH SERVICE
// =============================================================================

Table users {
  id            uuid          [pk, default: `gen_random_uuid()`]
  phone         varchar(15)   [unique, not null, note: 'E.164 format e.g. +919876543210']
  email         varchar(255)  [unique, null]
  created_at    timestamptz   [not null, default: `now()`]
  updated_at    timestamptz   [not null, default: `now()`]
  last_login    timestamptz   [null]
  is_deleted    boolean       [not null, default: false]

  indexes {
    phone        [unique, name: 'uq_users_phone']
    email        [unique, name: 'uq_users_email']
    is_deleted   [name: 'idx_users_is_deleted']
    created_at   [name: 'idx_users_created_at']
  }

  Note: 'Auth Service owner. Soft delete only — hard delete triggered by DPDPA PII purge on account.deletion_requested Kafka event.'
}


// [NEW V5] auth_sessions — JWT refresh token server-side store
// Required for 30-day sliding refresh token with forced revocation capability
Table auth_sessions {
  id              uuid          [pk, default: `gen_random_uuid()`]
  user_id         uuid          [not null, ref: > users.id]
  refresh_token_hash varchar(255) [unique, not null, note: 'SHA-256 of the raw refresh token stored in device keychain']
  device_id       varchar(255)  [null, note: 'Device fingerprint at session creation time']
  ip              inet          [null, note: 'IP at creation time for anomaly detection']
  user_agent      varchar(500)  [null]
  expires_at      timestamptz   [not null, note: 'now() + 30 days; sliding — extended on each valid use']
  revoked_at      timestamptz   [null, note: 'Set on logout, forced revocation, or password change']
  created_at      timestamptz   [not null, default: `now()`]

  indexes {
    user_id                [name: 'idx_auth_sessions_user_id']
    refresh_token_hash     [unique, name: 'uq_auth_sessions_token_hash']
    expires_at             [name: 'idx_auth_sessions_expires_at']
    (user_id, revoked_at)  [name: 'idx_auth_sessions_active', note: 'List all active sessions for a user: WHERE revoked_at IS NULL']
  }

  Note: '[V5 NEW] JWT refresh token store. On refresh: verify hash → extend expires_at → issue new access token. On forced logout: set revoked_at. Cleanup job purges expired rows daily.'
}


Table auth_events {
  id            uuid          [pk, default: `gen_random_uuid()`]
  user_id       uuid          [not null, ref: > users.id]
  event_type    varchar(50)   [not null, note: 'OTP_SENT | LOGIN_SUCCESS | LOGOUT | SESSION_EXPIRED']
  device_id     varchar(255)  [null]
  ip            inet          [null]
  timestamp     timestamptz   [not null, default: `now()`]

  indexes {
    user_id      [name: 'idx_auth_events_user_id']
    event_type   [name: 'idx_auth_events_event_type']
    timestamp    [name: 'idx_auth_events_timestamp']
  }

  Note: 'Append-only compliance audit trail. Forever retention.'
}


Table admin_actions {
  id            uuid          [pk, default: `gen_random_uuid()`]
  admin_id      uuid          [not null, ref: > users.id]
  action_type   varchar(100)  [not null]
  target_type   varchar(50)   [null, note: 'USER | PRODUCT | ORDER | REFUND | OFFER | STORE']
  target_id     uuid          [null]
  metadata      jsonb         [null]
  performed_at  timestamptz   [not null, default: `now()`]

  indexes {
    admin_id     [name: 'idx_admin_actions_admin_id']
    action_type  [name: 'idx_admin_actions_action_type']
    performed_at [name: 'idx_admin_actions_performed_at']
    target_type  [name: 'idx_admin_actions_target_type']
    target_id    [name: 'idx_admin_actions_target_id']
    (target_type, target_id) [name: 'idx_admin_actions_target']
  }

  Note: 'Append-only immutable admin audit log. target_type required to make target_id joinable.'
}


Table login_attempts {
  id            uuid          [pk, default: `gen_random_uuid()`]
  user_id       uuid          [null, ref: > users.id]
  phone         varchar(15)   [not null]
  ip            inet          [null]
  attempt_at    timestamptz   [not null, default: `now()`]
  success       boolean       [not null, default: false]

  indexes {
    phone                   [name: 'idx_login_attempts_phone']
    user_id                 [name: 'idx_login_attempts_user_id']
    attempt_at              [name: 'idx_login_attempts_attempt_at']
    (phone, attempt_at)     [name: 'idx_login_attempts_phone_time']
  }

  Note: 'Required for Flow 3.10 Account Locked. Tracks OTP/login attempts per phone for lockout logic.'
}


Table email_verifications {
  id            uuid          [pk, default: `gen_random_uuid()`]
  user_id       uuid          [not null, ref: > users.id]
  email         varchar(255)  [not null]
  token_hash    varchar(255)  [not null]
  verified_at   timestamptz   [null]
  expires_at    timestamptz   [not null, note: 'now() + 24 hours']

  indexes {
    user_id      [name: 'idx_email_verifications_user_id']
    token_hash   [unique, name: 'uq_email_verifications_token_hash']
    expires_at   [name: 'idx_email_verifications_expires_at']
  }

  Note: 'Required for Flow 3.11 Email Linkage.'
}


Table app_versions {
  platform        varchar(10)   [pk, note: 'ios | android']
  min_version     varchar(20)   [not null]
  latest_version  varchar(20)   [not null]
  force_update    boolean       [not null, default: false]
  updated_at      timestamptz   [not null, default: `now()`]

  Note: 'Required for Flows 1.2 and 1.3 version check / force update.'
}


// =============================================================================
// GROUP 2 — STORE SERVICE
// =============================================================================

Table stores {
  id              uuid          [pk, default: `gen_random_uuid()`]
  chain_id        uuid          [not null, ref: > chains.id, note: '[V5] Multi-chain support. Required by ES chain_id filters and chain-level analytics.']
  name            varchar(255)  [not null]
  store_type      varchar(20)   [not null, default: 'SUPERMARKET', note: '[V5] SUPERMARKET | CONVENIENCE | HYPERMARKET | PHARMACY — ClickHouse analytics segmentation']
  lat             decimal(10,7) [not null]
  lng             decimal(10,7) [not null]
  radius_m        integer       [not null, default: 100, note: 'Circular geofence radius in metres']
  short_code      varchar(20)   [unique, not null]
  address         varchar(500)  [null]
  city            varchar(100)  [null]
  state           varchar(100)  [null]
  gstin           varchar(20)   [null, note: '[V5] Store-level GSTIN for GST filing. Elasticsearch stores index field.']
  max_capacity    integer       [not null, default: 500, note: '[V5] Maximum store occupancy. Required by ClickHouse peak_hour_heatmap.max_occupancy_pct and TimescaleDB store_traffic.max_capacity.']
  is_open         boolean       [not null, default: true]
  ble_beacon_uuid uuid          [unique, null]
  created_at      timestamptz   [not null, default: `now()`]
  updated_at      timestamptz   [not null, default: `now()`]

  indexes {
    (lat, lng)          [name: 'idx_stores_lat_lng']
    short_code          [unique, name: 'uq_stores_short_code']
    ble_beacon_uuid     [unique, name: 'uq_stores_ble_beacon_uuid']
    chain_id            [name: 'idx_stores_chain_id']
    is_open             [name: 'idx_stores_is_open']
    store_type          [name: 'idx_stores_store_type']
  }

  Note: 'Store Service owner. chain_id required for multi-chain architecture. max_capacity feeds occupancy KPIs across TimescaleDB and ClickHouse.'
}


// [V5 NEW] geofence_polygons — Elasticsearch stores index has geofence: geo_shape
// Circular radius in stores table supports simple BLE entry detection.
// This table supports polygon geofencing for complex store layouts.
Table geofence_polygons {
  id              uuid          [pk, default: `gen_random_uuid()`]
  store_id        uuid          [unique, not null, ref: > stores.id, note: 'One polygon per store']
  polygon_wkt     text          [not null, note: 'WKT POLYGON format e.g. POLYGON((lng1 lat1, lng2 lat2, ...)) — indexed in Elasticsearch as geo_shape']
  updated_at      timestamptz   [not null, default: `now()`]

  indexes {
    store_id     [unique, name: 'uq_geofence_store_id']
    updated_at   [name: 'idx_geofence_updated_at']
  }

  Note: '[V5 NEW] Polygon geofence for complex store layouts. Synced to Elasticsearch stores index as geo_shape field for within-polygon entry detection. Falls back to stores.radius_m circle if polygon not configured.'
}


Table store_hours {
  id            uuid          [pk, default: `gen_random_uuid()`]
  store_id      uuid          [not null, ref: > stores.id]
  day_of_week   smallint      [not null, note: '0=Sunday ... 6=Saturday']
  open_time     time          [not null]
  close_time    time          [not null]
  is_holiday    boolean       [not null, default: false]
  updated_at    timestamptz   [not null, default: `now()`]

  indexes {
    (store_id, day_of_week)  [unique, name: 'uq_store_hours_store_day']
    store_id                 [name: 'idx_store_hours_store_id']
  }

  Note: 'Store hours for closed-screen detection.'
}


Table store_qr_tokens {
  id            uuid          [pk, default: `gen_random_uuid()`]
  token_hash    varchar(255)  [unique, not null]
  store_id      uuid          [not null, ref: > stores.id]
  issued_at     timestamptz   [not null, default: `now()`]
  expires_at    timestamptz   [not null, note: '5 minute TTL for QR freshness']
  is_used       boolean       [not null, default: false]

  indexes {
    token_hash   [unique, name: 'uq_store_qr_tokens_hash']
    store_id     [name: 'idx_store_qr_tokens_store_id']
    expires_at   [name: 'idx_store_qr_tokens_expires_at']
  }

  Note: 'Required for Flow 5.5. Single-use short-lived QR tokens prevent replay attacks.'
}


Table beacon_verifications {
  id            uuid          [pk, default: `gen_random_uuid()`]
  user_id       uuid          [not null, ref: > users.id]
  store_id      uuid          [not null, ref: > stores.id]
  beacon_uuid   uuid          [not null]
  detected_at   timestamptz   [not null, default: `now()`]

  indexes {
    user_id      [name: 'idx_beacon_verifications_user_id']
    store_id     [name: 'idx_beacon_verifications_store_id']
    (user_id, store_id, detected_at) [name: 'idx_beacon_verifications_composite']
  }

  Note: 'BLE session audit trail for dispute resolution.'
}


Table aisle_layout {
  id            uuid          [pk, default: `gen_random_uuid()`]
  store_id      uuid          [not null, ref: > stores.id]
  svg_data      text          [not null]
  updated_at    timestamptz   [not null, default: `now()`]

  indexes {
    store_id     [name: 'idx_aisle_layout_store_id']
    updated_at   [name: 'idx_aisle_layout_updated_at']
  }

  Note: 'AR navigation store map. Standardised from aisle_positions (GAP-C fix).'
}


Table shelf_positions {
  id            uuid          [pk, default: `gen_random_uuid()`]
  store_id      uuid          [not null, ref: > stores.id]
  sku_id        uuid          [not null, ref: > products.id]
  aisle_id      uuid          [not null, ref: > aisle_layout.id]
  slot          varchar(50)   [not null]
  coords_json   jsonb         [not null, note: '{"x": 120, "y": 340, "z": 1}']
  updated_at    timestamptz   [not null, default: `now()`]

  indexes {
    store_id     [name: 'idx_shelf_positions_store_id']
    sku_id       [name: 'idx_shelf_positions_sku_id']
    aisle_id     [name: 'idx_shelf_positions_aisle_id']
    (store_id, sku_id) [name: 'idx_shelf_positions_store_sku']
  }

  Note: 'AR item-found coordinates. Standardised from shelf_coords (GAP-C fix).'
}


// =============================================================================
// GROUP 3 — CATALOG SERVICE
// =============================================================================

// [V5] categories now chain-scoped (not store-scoped)
// At 15M stores creating per-store category trees is operationally impossible
Table categories {
  id              uuid          [pk, default: `gen_random_uuid()`]
  name            varchar(255)  [not null]
  parent_id       uuid          [null, ref: > categories.id]
  chain_id        uuid          [not null, ref: > chains.id, note: '[V5] Categories are chain-scoped. All stores in a chain share the same category tree. store_id removed — was wrong to have 15M separate trees.']
  product_count   integer       [not null, default: 0]
  image_url       varchar(500)  [null]
  created_at      timestamptz   [not null, default: `now()`]
  updated_at      timestamptz   [not null, default: `now()`]

  indexes {
    chain_id       [name: 'idx_categories_chain_id']
    parent_id      [name: 'idx_categories_parent_id']
    (chain_id, name) [name: 'idx_categories_chain_name']
  }

  Note: '[V5 FIX] Chain-scoped categories. Original schema had store_id which would require 15M separate category trees for 15M stores — architecturally wrong. All stores in a chain share one category hierarchy.'
}


Table products {
  id                    uuid          [pk, default: `gen_random_uuid()`]
  barcode               varchar(100)  [not null, note: 'EAN-13 or internal barcode']
  name                  varchar(500)  [not null]
  brand                 varchar(255)  [null, note: '[V5] Brand name e.g. "Amul", "Nestle". Elasticsearch autocomplete_analyzer on brand field. WatermelonDB catalog_cache source of truth.']
  description           text          [null]
  hsn_code              varchar(20)   [not null]
  mrp                   decimal(10,2) [not null]
  image_url             varchar(500)  [null]
  store_id              uuid          [not null, ref: > stores.id]
  category_id           uuid          [null, ref: > categories.id]
  shelf_id              uuid          [null, ref: > shelf_positions.id]
  sold_by_weight        boolean       [not null, default: false]
  weight_unit           varchar(10)   [null, note: 'kg | g | 100g — required when sold_by_weight=true']
  weight_grams          integer       [null, note: '[V5] Package weight in grams. ES index field. Used for weight-based sort and filter.']
  unit_of_measure       varchar(20)   [null, note: '[V5] kg | g | ml | l | pcs | pack — ES index field. WatermelonDB source of truth.']
  pack_size             varchar(50)   [null, note: '[V5] Display pack description e.g. "500g", "6 pack", "1L". ES index field.']
  rfid_required         boolean       [not null, default: false, note: '[V5] Whether this product has RFID tags requiring deactivation at exit. WatermelonDB catalog_cache.rfid_required source of truth. Exit Validation Service checks this.']
  cold_storage_required boolean       [not null, default: false, note: '[V5] Refrigeration required. ES index field. Supply chain routing and store layout.']
  tags                  jsonb         [null, note: '[V5] Array of tags e.g. ["organic","gluten_free","vegan","diabetic_friendly"]. Elasticsearch keyword array for filtering. JSONB allows array storage in PG.']
  is_active             boolean       [not null, default: true]
  created_at            timestamptz   [not null, default: `now()`]
  updated_at            timestamptz   [not null, default: `now()`, note: 'WatermelonDB differential sync uses this']

  indexes {
    (barcode, store_id) [unique, name: 'uq_products_barcode_store']
    store_id            [name: 'idx_products_store_id']
    category_id         [name: 'idx_products_category_id']
    hsn_code            [name: 'idx_products_hsn_code']
    shelf_id            [name: 'idx_products_shelf_id']
    sold_by_weight      [name: 'idx_products_sold_by_weight']
    rfid_required       [name: 'idx_products_rfid_required']
    is_active           [name: 'idx_products_is_active']
    updated_at          [name: 'idx_products_updated_at', note: 'Powers WatermelonDB catalog sync']
    brand               [name: 'idx_products_brand']
  }

  Note: '[V5] Added brand, weight_grams, unit_of_measure, pack_size, rfid_required, cold_storage_required, tags. These were present in Elasticsearch and WatermelonDB but missing from the source of truth. All ES/WatermelonDB fields must have a PG source column.'
}


Table pricing_rules {
  id              uuid          [pk, default: `gen_random_uuid()`]
  product_id      uuid          [not null, ref: > products.id]
  store_id        uuid          [not null, ref: > stores.id]
  price           decimal(10,2) [not null]
  effective_from  timestamptz   [not null]
  effective_to    timestamptz   [null]
  created_at      timestamptz   [not null, default: `now()`]

  indexes {
    product_id     [name: 'idx_pricing_rules_product_id']
    store_id       [name: 'idx_pricing_rules_store_id']
    (product_id, store_id, effective_from) [name: 'idx_pricing_rules_active']
  }

  Note: 'Time-bounded pricing. Cart always fetches latest active rule.'
}


Table offers {
  id              uuid          [pk, default: `gen_random_uuid()`]
  name            varchar(255)  [not null]
  type            varchar(50)   [not null, note: 'flash | combo | coupon | loyalty_bonus | personal']
  discount_type   varchar(20)   [not null, note: 'PERCENT | FLAT | BOGO']
  value           decimal(10,2) [not null]
  min_cart        decimal(10,2) [null]
  max_discount    decimal(10,2) [null]
  starts_at       timestamptz   [null]
  ends_at         timestamptz   [null]
  store_id        uuid          [not null, ref: > stores.id]
  active          boolean       [not null, default: true]
  created_at      timestamptz   [not null, default: `now()`]
  updated_at      timestamptz   [not null, default: `now()`]

  indexes {
    store_id       [name: 'idx_offers_store_id']
    type           [name: 'idx_offers_type']
    starts_at      [name: 'idx_offers_starts_at']
    ends_at        [name: 'idx_offers_ends_at']
    active         [name: 'idx_offers_active']
    (store_id, active) [name: 'idx_offers_store_active']
  }

  Note: 'starts_at+ends_at define flash sale window. Detailed rule conditions in offer_rules.'
}


Table offer_rules {
  id              uuid          [pk, default: `gen_random_uuid()`]
  offer_id        uuid          [not null, ref: > offers.id]
  rule_type       varchar(50)   [not null, note: 'SKU_MATCH | CATEGORY_MATCH | MIN_QTY | TIME_WINDOW | USER_SEGMENT']
  condition_json  jsonb         [not null]
  action_json     jsonb         [not null]
  store_id        uuid          [not null, ref: > stores.id]
  active          boolean       [not null, default: true]
  created_at      timestamptz   [not null, default: `now()`]
  updated_at      timestamptz   [not null, default: `now()`]

  indexes {
    offer_id       [name: 'idx_offer_rules_offer_id']
    store_id       [name: 'idx_offer_rules_store_id']
    (store_id, active) [name: 'idx_offer_rules_store_active', note: 'Powers Redis offer_rules:{store_id} cache refresh']
  }

  Note: 'Separate table from offers. Structured conditions/actions evaluated by Cart Service. Source for Redis offer_rules:{store_id} cache.'
}


Table combo_rules {
  id              uuid          [pk, default: `gen_random_uuid()`]
  name            varchar(255)  [not null]
  discount_type   varchar(20)   [not null, default: 'FLAT', note: 'PERCENT | FLAT | FREE_ITEM']
  discount_value  decimal(10,2) [not null]
  store_id        uuid          [not null, ref: > stores.id]
  active          boolean       [not null, default: true]
  created_at      timestamptz   [not null, default: `now()`]
  updated_at      timestamptz   [not null, default: `now()`]

  indexes {
    store_id       [name: 'idx_combo_rules_store_id']
    active         [name: 'idx_combo_rules_active']
  }
}


Table combo_items {
  id              uuid          [pk, default: `gen_random_uuid()`]
  combo_id        uuid          [not null, ref: > combo_rules.id]
  sku_id          uuid          [not null, ref: > products.id]
  required_qty    integer       [not null, default: 1]
  created_at      timestamptz   [not null, default: `now()`]

  indexes {
    combo_id       [name: 'idx_combo_items_combo_id']
    sku_id         [name: 'idx_combo_items_sku_id']
    (combo_id, sku_id) [unique, name: 'uq_combo_items_combo_sku']
  }
}


Table recipes {
  id              uuid          [pk, default: `gen_random_uuid()`]
  name            varchar(255)  [not null]
  store_id        uuid          [not null, ref: > stores.id]
  image_url       varchar(500)  [null]
  description     text          [null]
  created_at      timestamptz   [not null, default: `now()`]
  updated_at      timestamptz   [not null, default: `now()`]

  indexes {
    store_id       [name: 'idx_recipes_store_id']
  }
}


Table recipe_ingredients {
  id              uuid          [pk, default: `gen_random_uuid()`]
  recipe_id       uuid          [not null, ref: > recipes.id]
  sku_id          uuid          [not null, ref: > products.id]
  quantity        decimal(8,3)  [not null]
  unit            varchar(20)   [not null, note: 'kg | g | l | ml | pcs | tbsp']
  created_at      timestamptz   [not null, default: `now()`]

  indexes {
    recipe_id      [name: 'idx_recipe_ingredients_recipe_id']
    sku_id         [name: 'idx_recipe_ingredients_sku_id']
    (recipe_id, sku_id) [unique, name: 'uq_recipe_ingredients_recipe_sku']
  }
}


// [V5 NEW] feature_flags — source of truth for WatermelonDB feature_flags_cache and Redis feature_flags:{store_id}
Table feature_flags {
  id              uuid          [pk, default: `gen_random_uuid()`]
  store_id        uuid          [null, ref: > stores.id, note: 'NULL = global flag for all stores; non-null = store-specific override']
  chain_id        uuid          [null, ref: > chains.id, note: 'NULL = global; non-null = chain-level flag affecting all stores in the chain']
  flag_key        varchar(100)  [not null, note: 'e.g. ar_navigation | upi_lite_v2 | rfid_exit | self_checkout']
  enabled         boolean       [not null, default: false]
  rollout_pct     smallint      [not null, default: 0, note: '0-100 — percentage of users to whom this flag is active']
  variant         varchar(50)   [null, note: 'A/B variant if applicable e.g. "control" | "treatment_a"']
  payload_json    jsonb         [null, note: 'Extra config payload for the flag']
  created_at      timestamptz   [not null, default: `now()`]
  updated_at      timestamptz   [not null, default: `now()`]

  indexes {
    store_id       [name: 'idx_feature_flags_store_id']
    chain_id       [name: 'idx_feature_flags_chain_id']
    flag_key       [name: 'idx_feature_flags_key']
    (store_id, flag_key) [name: 'idx_feature_flags_store_key']
  }

  Note: '[V5 NEW] Source of truth for WatermelonDB feature_flags_cache and Redis feature_flags:{store_id} (5min TTL). Platform Service owns writes.'
}


// =============================================================================
// GROUP 4 — CART SERVICE
// =============================================================================

Table coupons {
  id              uuid          [pk, default: `gen_random_uuid()`]
  code            varchar(50)   [unique, not null]
  discount_value  decimal(10,2) [not null]
  discount_type   varchar(20)   [not null, default: 'FLAT', note: 'FLAT | PERCENT']
  min_order       decimal(10,2) [null]
  max_uses        integer       [null]
  per_user_limit  integer       [not null, default: 1]
  expires_at      timestamptz   [null]
  active          boolean       [not null, default: true]
  created_at      timestamptz   [not null, default: `now()`]
  updated_at      timestamptz   [not null, default: `now()`]

  indexes {
    code           [unique, name: 'uq_coupons_code']
    expires_at     [name: 'idx_coupons_expires_at']
    active         [name: 'idx_coupons_active']
  }
}


// [V5 FIX] coupon_usage: changed coupon_code varchar FK to coupon_id uuid FK
// FK on non-PK column (coupons.code) is unsafe — codes can be updated
Table coupon_usage {
  id              uuid          [pk, default: `gen_random_uuid()`]
  user_id         uuid          [not null, ref: > users.id]
  coupon_id       uuid          [not null, ref: > coupons.id, note: '[V5 FIX] Changed from coupon_code varchar FK to coupon_id uuid FK. FK on non-PK is unsafe — coupon codes can change.']
  order_id        uuid          [null, ref: > orders.id]
  used_at         timestamptz   [not null, default: `now()`]

  indexes {
    user_id        [name: 'idx_coupon_usage_user_id']
    coupon_id      [name: 'idx_coupon_usage_coupon_id']
    (user_id, coupon_id) [name: 'idx_coupon_usage_user_coupon', note: 'Powers per_user_limit enforcement']
  }
}


Table hsn_gst_rates {
  hsn_code        varchar(20)   [pk]
  cgst_rate       decimal(5,2)  [not null]
  sgst_rate       decimal(5,2)  [not null]
  igst_rate       decimal(5,2)  [not null]
  effective_from  timestamptz   [not null, default: `now()`]

  indexes {
    effective_from [name: 'idx_hsn_gst_effective_from']
  }

  Note: 'Master GST rate lookup. Aggressively cached in Redis hsn_gst:{hsn_code}.'
}


// =============================================================================
// GROUP 5 — INVENTORY SERVICE
// =============================================================================

Table stock {
  id              uuid          [pk, default: `gen_random_uuid()`]
  sku_id          uuid          [not null, ref: > products.id]
  store_id        uuid          [not null, ref: > stores.id]
  qty_available   integer       [not null, default: 0, note: 'Units available = qty_on_hand - qty_reserved']
  qty_reserved    integer       [not null, default: 0, note: 'Units held by active carts']
  qty_on_hand     integer       [not null, default: 0, note: 'Physical count = qty_available + qty_reserved']
  created_at      timestamptz   [not null, default: `now()`]
  updated_at      timestamptz   [not null, default: `now()`]

  indexes {
    (sku_id, store_id)   [unique, name: 'uq_stock_sku_store']
    store_id             [name: 'idx_stock_store_id']
    qty_available        [name: 'idx_stock_qty_available']
    updated_at           [name: 'idx_stock_updated_at']
  }

  Note: 'CRITICAL — most important gap from v1. qty_on_hand invariant: qty_available + qty_reserved. Hold: UPDATE SET qty_available-1, qty_reserved+1 WHERE qty_available > 0 (atomic compare-and-swap).'
}


// =============================================================================
// GROUP 6 — ORDER SERVICE
// =============================================================================

Table orders {
  id                       uuid          [pk, default: `gen_random_uuid()`]
  user_id                  uuid          [not null, ref: > users.id]
  store_id                 uuid          [not null, ref: > stores.id]
  payment_id               uuid          [null, ref: > payments.id, note: '[V5] Direct payment reference. Avoids separate query for support/audit. Set once payment is confirmed.']
  status                   varchar(30)   [not null, note: 'PENDING | PAYMENT_PROCESSING | CONFIRMED | EXIT_VALIDATED | COMPLETED | CANCELLED | REFUNDED']
  subtotal                 decimal(12,2) [not null]
  gst                      decimal(12,2) [not null]
  discount                 decimal(12,2) [not null, default: 0]
  total                    decimal(12,2) [not null]
  coupon_code              varchar(50)   [null, ref: > coupons.code, note: 'Denormalised for support visibility']
  loyalty_points_redeemed  integer       [not null, default: 0]
  exit_validated_at        timestamptz   [null]
  created_at               timestamptz   [not null, default: `now()`]
  updated_at               timestamptz   [not null, default: `now()`]

  indexes {
    user_id          [name: 'idx_orders_user_id']
    store_id         [name: 'idx_orders_store_id']
    payment_id       [name: 'idx_orders_payment_id']
    status           [name: 'idx_orders_status']
    created_at       [name: 'idx_orders_created_at']
    (user_id, created_at) [name: 'idx_orders_user_created']
    coupon_code      [name: 'idx_orders_coupon_code']
  }

  Note: '[V5] Added payment_id for direct payment lookup without join. PARTITION BY RANGE(created_at) required before Phase 2 scale.'
}


Table order_items {
  id              uuid          [pk, default: `gen_random_uuid()`]
  order_id        uuid          [not null, ref: > orders.id]
  sku_id          uuid          [not null, ref: > products.id]
  qty             integer       [not null]
  unit_price      decimal(10,2) [not null, note: 'Price snapshot at time of purchase']
  gst_amount      decimal(10,2) [not null]
  rfid_tag_id     varchar(100)  [null, note: 'RFID tag for exit gate deactivation']
  created_at      timestamptz   [not null, default: `now()`]

  indexes {
    order_id       [name: 'idx_order_items_order_id']
    sku_id         [name: 'idx_order_items_sku_id']
    rfid_tag_id    [name: 'idx_order_items_rfid_tag_id']
    created_at     [name: 'idx_order_items_created_at']
  }

  Note: 'PARTITION BY RANGE(created_at) required before Phase 2. Prices are snapshots.'
}


Table refunds {
  id                  uuid          [pk, default: `gen_random_uuid()`]
  order_id            uuid          [not null, ref: > orders.id]
  payment_id          uuid          [not null, ref: > payments.id]
  sku_id              uuid          [null, ref: > products.id]
  amount              decimal(10,2) [not null]
  reason              text          [null]
  status              varchar(30)   [not null, note: 'PENDING → PROCESSING → CREDITED | FAILED']
  gateway_refund_id   varchar(255)  [null]
  created_at          timestamptz   [not null, default: `now()`]
  updated_at          timestamptz   [not null, default: `now()`]

  indexes {
    order_id           [name: 'idx_refunds_order_id']
    payment_id         [name: 'idx_refunds_payment_id']
    status             [name: 'idx_refunds_status']
  }
}


Table refund_requests {
  id              uuid          [pk, default: `gen_random_uuid()`]
  order_id        uuid          [not null, ref: > orders.id]
  user_id         uuid          [not null, ref: > users.id]
  sku_id          uuid          [null, ref: > products.id]
  reason          text          [not null]
  image_url       varchar(500)  [null, note: 'S3: refunds/{order_id}/{refund_id}/{filename}.jpg']
  status          varchar(30)   [not null, default: 'SUBMITTED', note: 'SUBMITTED | UNDER_REVIEW | APPROVED | REJECTED']
  created_at      timestamptz   [not null, default: `now()`]
  updated_at      timestamptz   [not null, default: `now()`]

  indexes {
    order_id       [name: 'idx_refund_requests_order_id']
    user_id        [name: 'idx_refund_requests_user_id']
    status         [name: 'idx_refund_requests_status']
  }
}


Table approval_workflow {
  id                  uuid          [pk, default: `gen_random_uuid()`]
  refund_request_id   uuid          [not null, ref: > refund_requests.id]
  reviewer_id         uuid          [not null, ref: > users.id]
  status              varchar(30)   [not null, note: 'PENDING_REVIEW | APPROVED | REJECTED | ESCALATED']
  decision_note       text          [null]
  actioned_at         timestamptz   [null]
  created_at          timestamptz   [not null, default: `now()`]

  indexes {
    refund_request_id  [name: 'idx_approval_workflow_request_id']
    reviewer_id        [name: 'idx_approval_workflow_reviewer_id']
    status             [name: 'idx_approval_workflow_status']
  }

  Note: 'Internal staff refund review. Three-table refund flow: refund_requests → approval_workflow → refunds.'
}


// =============================================================================
// GROUP 7 — PAYMENT SERVICE
// =============================================================================

Table payments {
  id                uuid          [pk, default: `gen_random_uuid()`]
  order_id          uuid          [not null, ref: > orders.id]
  gateway           varchar(50)   [not null, note: 'razorpay | paytm | upi | cashfree | payu']
  method            varchar(50)   [not null, note: 'UPI | CARD | NETBANKING | WALLET | CARD_TOKENIZED | SPLIT']
  status            varchar(30)   [not null, note: 'INITIATED | PENDING | SUCCESS | FAILED | REFUNDED']
  amount            decimal(12,2) [not null]
  gateway_ref       varchar(255)  [null]
  idempotency_key   varchar(255)  [unique, not null]
  retry_count       integer       [not null, default: 0, note: 'Max 3 retries across gateways']
  created_at        timestamptz   [not null, default: `now()`]
  updated_at        timestamptz   [not null, default: `now()`]

  indexes {
    order_id         [name: 'idx_payments_order_id']
    status           [name: 'idx_payments_status']
    gateway_ref      [name: 'idx_payments_gateway_ref']
    idempotency_key  [unique, name: 'uq_payments_idempotency_key']
    gateway          [name: 'idx_payments_gateway']
  }
}


Table tokenized_cards {
  id                uuid          [pk, default: `gen_random_uuid()`]
  user_id           uuid          [not null, ref: > users.id]
  razorpay_token    varchar(255)  [not null, note: 'Razorpay vault token — never raw card data']
  card_last4        char(4)       [not null]
  card_brand        varchar(20)   [not null, note: 'VISA | MASTERCARD | RUPAY | AMEX']
  is_active         boolean       [not null, default: true]
  created_at        timestamptz   [not null, default: `now()`]

  indexes {
    user_id          [name: 'idx_tokenized_cards_user_id']
    is_active        [name: 'idx_tokenized_cards_is_active']
  }
}


Table reconciliation_log {
  id              uuid          [pk, default: `gen_random_uuid()`]
  payment_id      uuid          [not null, ref: > payments.id]
  gateway_ref     varchar(255)  [not null]
  settled_amount  decimal(12,2) [not null]
  status          varchar(30)   [not null, note: 'MATCHED | MISMATCH | PENDING | DISPUTE']
  reconciled_at   timestamptz   [not null, default: `now()`]

  indexes {
    payment_id     [name: 'idx_reconciliation_log_payment_id']
    status         [name: 'idx_reconciliation_log_status']
    gateway_ref    [name: 'idx_reconciliation_log_gateway_ref']
  }
}


// [GAP-C FIX] payment_audit_log — renamed from payment_events to resolve dual-role naming conflict
Table payment_audit_log {
  id              uuid          [pk, default: `gen_random_uuid()`]
  payment_id      uuid          [not null, ref: > payments.id]
  order_id        uuid          [not null, ref: > orders.id]
  user_id         uuid          [not null, ref: > users.id]
  store_id        uuid          [not null, ref: > stores.id, note: '[V5] Added store_id for direct audit queries without chaining joins payment→order→store']
  event_type      varchar(50)   [not null, note: 'PAYMENT_INITIATED | PAYMENT_SUCCESS | PAYMENT_FAILED | REFUND_INITIATED | REFUND_COMPLETED | CHARGEBACK']
  amount          decimal(12,2) [not null]
  gateway         varchar(50)   [not null]
  gateway_ref     varchar(255)  [null]
  metadata        jsonb         [null]
  recorded_at     timestamptz   [not null, default: `now()`]

  indexes {
    payment_id     [name: 'idx_payment_audit_log_payment_id']
    order_id       [name: 'idx_payment_audit_log_order_id']
    user_id        [name: 'idx_payment_audit_log_user_id']
    store_id       [name: 'idx_payment_audit_log_store_id']
    event_type     [name: 'idx_payment_audit_log_event_type']
    recorded_at    [name: 'idx_payment_audit_log_recorded_at']
  }

  Note: 'Append-only immutable compliance audit. Forever retention. store_id added for direct audit queries.'
}


// =============================================================================
// GROUP 8 — LOYALTY SERVICE
// =============================================================================

Table loyalty_ledger {
  id              uuid          [pk, default: `gen_random_uuid()`]
  user_id         uuid          [not null, ref: > users.id]
  order_id        uuid          [null, ref: > orders.id]
  points_change   integer       [not null]
  type            varchar(30)   [not null, note: 'EARN | REDEEM | EXPIRE | BONUS | ADJUSTMENT']
  balance_after   integer       [not null]
  notes           text          [null]
  created_at      timestamptz   [not null, default: `now()`]

  indexes {
    user_id        [name: 'idx_loyalty_ledger_user_id']
    order_id       [name: 'idx_loyalty_ledger_order_id']
    (user_id, created_at) [name: 'idx_loyalty_ledger_user_created']
  }

  Note: 'Append-only. True balance = SUM(points_change). balance_after is perf snapshot.'
}


Table loyalty_tiers {
  tier_name       varchar(50)   [pk, note: 'BRONZE | SILVER | GOLD | PLATINUM']
  min_points      integer       [not null]
  max_points      integer       [null]
  benefits_json   jsonb         [not null]
  updated_at      timestamptz   [not null, default: `now()`]

  indexes {
    min_points     [name: 'idx_loyalty_tiers_min_points']
  }
}


Table loyalty_cards {
  id              uuid          [pk, default: `gen_random_uuid()`]
  user_id         uuid          [unique, not null, ref: > users.id]
  card_number     varchar(50)   [unique, not null]
  barcode_data    varchar(500)  [not null]
  issued_at       timestamptz   [not null, default: `now()`]

  indexes {
    user_id        [unique, name: 'uq_loyalty_cards_user_id']
    card_number    [unique, name: 'uq_loyalty_cards_number']
  }
}


Table loyalty_tier_history {
  id                uuid          [pk, default: `gen_random_uuid()`]
  user_id           uuid          [not null, ref: > users.id]
  old_tier          varchar(50)   [not null, ref: > loyalty_tiers.tier_name]
  new_tier          varchar(50)   [not null, ref: > loyalty_tiers.tier_name]
  changed_at        timestamptz   [not null, default: `now()`]
  trigger_order_id  uuid          [null, ref: > orders.id]

  indexes {
    user_id          [name: 'idx_loyalty_tier_history_user_id']
    changed_at       [name: 'idx_loyalty_tier_history_changed_at']
  }
}


// =============================================================================
// GROUP 9 — EXIT VALIDATION SERVICE
// =============================================================================

Table exit_tokens {
  id              uuid          [pk, default: `gen_random_uuid()`]
  order_id        uuid          [not null, ref: > orders.id]
  token_hash      varchar(255)  [unique, not null]
  created_at      timestamptz   [not null, default: `now()`]
  expires_at      timestamptz   [not null, note: '10-minute TTL for exit QR — corrected from 30min to match 100M scale security guidance. One-time use enforced via Redis exit_token_used:{jti}.']
  status          varchar(20)   [not null, default: 'VALID', note: 'VALID → USED | EXPIRED | DENIED']
  used_at         timestamptz   [null]
  gate_id         varchar(50)   [null]

  indexes {
    order_id       [name: 'idx_exit_tokens_order_id']
    token_hash     [unique, name: 'uq_exit_tokens_hash']
    status         [name: 'idx_exit_tokens_status']
    expires_at     [name: 'idx_exit_tokens_expires_at']
    created_at     [name: 'idx_exit_tokens_created_at']
  }

  Note: '[V5] TTL corrected to 10 minutes. One-time use atomically enforced via Redis SET exit_token_used:{jti} 1 EX 600 NX.'
}


Table override_log {
  id              uuid          [pk, default: `gen_random_uuid()`]
  exit_token_id   uuid          [not null, ref: > exit_tokens.id]
  staff_id        uuid          [not null, ref: > users.id]
  reason_code     varchar(50)   [not null, note: 'SYSTEM_ERROR | RFID_MISMATCH | MANAGER_OVERRIDE | PAYMENT_PENDING']
  override_at     timestamptz   [not null, default: `now()`]

  indexes {
    exit_token_id  [name: 'idx_override_log_exit_token_id']
    staff_id       [name: 'idx_override_log_staff_id']
    override_at    [name: 'idx_override_log_override_at']
  }

  Note: 'Append-only compliance log. Every gate override requires a reason code.'
}


// =============================================================================
// GROUP 10 — WAREHOUSE SERVICE
// =============================================================================

// [V5 NEW] vendors table — required by TimescaleDB supply_chain_events.vendor_id FK
Table vendors {
  id              uuid          [pk, default: `gen_random_uuid()`]
  name            varchar(255)  [not null]
  gstin           varchar(20)   [null, note: 'GST Identification Number — India compliance']
  contact_phone   varchar(15)   [null]
  contact_email   varchar(255)  [null]
  address         varchar(500)  [null]
  is_active       boolean       [not null, default: true]
  created_at      timestamptz   [not null, default: `now()`]
  updated_at      timestamptz   [not null, default: `now()`]

  indexes {
    name           [name: 'idx_vendors_name']
    gstin          [name: 'idx_vendors_gstin']
    is_active      [name: 'idx_vendors_is_active']
  }

  Note: '[V5 NEW] Required by TimescaleDB supply_chain_events.vendor_id FK. Warehouse Service owner.'
}


Table warehouse_stock {
  id              uuid          [pk, default: `gen_random_uuid()`]
  sku_id          uuid          [not null, ref: > products.id]
  warehouse_id    varchar(100)  [not null, note: 'Warehouse identifier e.g. WH-BLR-01. VARCHAR kept (human-readable IDs). TimescaleDB supply_chain_events.warehouse_id corrected to TEXT to match.']
  qty_available   integer       [not null, default: 0]
  batch_no        varchar(100)  [null]
  expiry          date          [null]
  created_at      timestamptz   [not null, default: `now()`]
  updated_at      timestamptz   [not null, default: `now()`]

  indexes {
    (sku_id, warehouse_id) [name: 'idx_warehouse_stock_sku_warehouse']
    warehouse_id           [name: 'idx_warehouse_stock_warehouse_id']
    expiry                 [name: 'idx_warehouse_stock_expiry']
    updated_at             [name: 'idx_warehouse_stock_updated_at']
  }
}


Table transfers {
  id                uuid          [pk, default: `gen_random_uuid()`]
  sku_id            uuid          [not null, ref: > products.id]
  from_warehouse_id varchar(100)  [not null]
  to_store_id       uuid          [not null, ref: > stores.id]
  qty               integer       [not null]
  transfer_note     text          [null]
  status            varchar(30)   [not null, default: 'PENDING', note: 'PENDING | DISPATCHED | IN_TRANSIT | RECEIVED | CANCELLED']
  created_at        timestamptz   [not null, default: `now()`]
  dispatched_at     timestamptz   [null]
  received_at       timestamptz   [null]

  indexes {
    sku_id           [name: 'idx_transfers_sku_id']
    to_store_id      [name: 'idx_transfers_to_store_id']
    status           [name: 'idx_transfers_status']
    created_at       [name: 'idx_transfers_created_at']
    dispatched_at    [name: 'idx_transfers_dispatched_at']
    received_at      [name: 'idx_transfers_received_at']
  }
}


// =============================================================================
// GROUP 11 — NOTIFICATION SERVICE
// =============================================================================

Table user_notification_prefs {
  user_id             uuid          [pk, ref: > users.id]
  whatsapp_enabled    boolean       [not null, default: true]
  sms_enabled         boolean       [not null, default: true]
  push_enabled        boolean       [not null, default: true]
  email_enabled       boolean       [not null, default: false]
  updated_at          timestamptz   [not null, default: `now()`]

  Note: 'Required for Flow B-4. Notification Service reads this before dispatching.'
}


Table notification_delivery_log {
  id                    uuid          [pk, default: `gen_random_uuid()`]
  user_id               uuid          [not null, ref: > users.id]
  channel               varchar(20)   [not null, note: 'WHATSAPP | SMS | PUSH | EMAIL']
  status                varchar(20)   [not null, note: 'SENT | DELIVERED | FAILED | BOUNCED']
  notification_type     varchar(50)   [not null, note: 'OTP | ORDER_CONFIRMATION | REFUND | LOYALTY | PROMOTIONAL | TICKET_UPDATE']
  reference_id          uuid          [null]
  reference_type        varchar(50)   [null, note: 'ORDER | REFUND | TICKET | OTP']
  provider_message_id   varchar(255)  [null, note: 'Twilio SID, FCM message_id — for delivery webhook lookup']
  error_details         text          [null]
  sent_at               timestamptz   [not null, default: `now()`]
  delivered_at          timestamptz   [null]

  indexes {
    user_id             [name: 'idx_notification_delivery_log_user_id']
    channel             [name: 'idx_notification_delivery_log_channel']
    status              [name: 'idx_notification_delivery_log_status']
    sent_at             [name: 'idx_notification_delivery_log_sent_at']
    reference_id        [name: 'idx_notification_delivery_log_reference_id']
    provider_message_id [name: 'idx_notification_delivery_log_provider_msg_id']
  }
}


// =============================================================================
// GROUP 12 — SUPPORT SERVICE
// =============================================================================

Table tickets {
  id              uuid          [pk, default: `gen_random_uuid()`]
  user_id         uuid          [not null, ref: > users.id]
  order_id        uuid          [null, ref: > orders.id]
  subject         varchar(500)  [not null]
  status          varchar(30)   [not null, default: 'OPEN', note: 'OPEN | IN_PROGRESS | ESCALATED | RESOLVED | CLOSED']
  priority        varchar(5)    [not null, default: 'P3', note: '[V5] P1 | P2 | P3 | P4 — required by Elasticsearch support_tickets index which has priority field. Source of truth added here.']
  assigned_to     uuid          [null, ref: > users.id]
  sla_target      timestamptz   [not null, note: 'created_at + 2hr; escalation triggered if unresolved']
  created_at      timestamptz   [not null, default: `now()`]
  updated_at      timestamptz   [not null, default: `now()`]
  resolved_at     timestamptz   [null]

  indexes {
    user_id        [name: 'idx_tickets_user_id']
    order_id       [name: 'idx_tickets_order_id']
    status         [name: 'idx_tickets_status']
    priority       [name: 'idx_tickets_priority']
    assigned_to    [name: 'idx_tickets_assigned_to']
    sla_target     [name: 'idx_tickets_sla_target']
    created_at     [name: 'idx_tickets_created_at']
    updated_at     [name: 'idx_tickets_updated_at']
  }

  Note: '[V5] Added priority column P1|P2|P3|P4. ES support_tickets index has this field but PG source was missing it.'
}


Table ticket_messages {
  id              uuid          [pk, default: `gen_random_uuid()`]
  ticket_id       uuid          [not null, ref: > tickets.id]
  sender_id       uuid          [null, ref: > users.id]
  sender_role     varchar(20)   [not null, note: 'CUSTOMER | AGENT | SYSTEM | BOT']
  message         text          [not null]
  sent_at         timestamptz   [not null, default: `now()`]

  indexes {
    ticket_id      [name: 'idx_ticket_messages_ticket_id']
    sender_id      [name: 'idx_ticket_messages_sender_id']
    (ticket_id, sent_at) [name: 'idx_ticket_messages_ticket_sent']
  }
}


// =============================================================================
// TABLE GROUPS
// =============================================================================

TableGroup chain_service {
  chains
}

TableGroup auth_service {
  users
  auth_sessions
  auth_events
  admin_actions
  login_attempts
  email_verifications
  app_versions
}

