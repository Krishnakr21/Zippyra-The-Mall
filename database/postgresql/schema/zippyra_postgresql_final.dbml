  stores
  geofence_polygons
  store_hours
  store_qr_tokens
  beacon_verifications
  aisle_layout
  shelf_positions
}

TableGroup catalog_service {
  categories
  products
  pricing_rules
  offers
  offer_rules
  combo_rules
  combo_items
  recipes
  recipe_ingredients
  feature_flags
}

TableGroup cart_service {
  coupons
  coupon_usage
  hsn_gst_rates
}

TableGroup inventory_service {
  stock
}

TableGroup order_service {
  orders
  order_items
  refunds
  refund_requests
  approval_workflow
}

TableGroup payment_service {
  payments
  tokenized_cards
  reconciliation_log
